<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>CSE Motors - Home</title>
</head>
<body>
    <div class="site-container">
        <%- include("./partials/header") %>
        <%- include("./partials/navigation") %>
        
        <main class="home">
            <section class="hero">
                <div class="hero-content">
                    <h1>Welcome to CSE Motors!</h1>
                    <picture>
                        <source media="(max-width: 600px)" srcset="/images/hero.jpg">
                        <img src="/images/delorean.jpg" alt="DMC Delorean" loading="lazy">
                    </picture>
                    <div class="car-details">
                        <h2>DMC Delorean</h2>
                        <ul class="delorean-features">
                            <li>3 Cup holders</li>
                            <li>Superman doors</li>
                            <li>Fuzzy dice!</li>
                        </ul>
                        <a href="#" class="button">Own Today</a>
                    </div>
                </div>
            </section>

            <section class="upgrades">
                <h2>Delorean Upgrades</h2>
                <div class="upgrade-grid">
                    <div class="upgrade-item">
                        <img src="/images/flux-capacitor.jpg" alt="Flux Capacitor">
                        <p>Flux Capacitor</p>
                    </div>
                    <div class="upgrade-item">
                        <img src="/images/flame-details.jpg" alt="Flame Details">
                        <p>Flame Details</p>
                    </div>
                    <div class="upgrade-item">
                        <img src="/images/bumper-stickers.jpg" alt="Bumper Stickers">
                        <p>Bumper Stickers</p>
                    </div>
                    <div class="upgrade-item">
                        <img src="/images/hub-cap.jpg" alt="Hub Cap">
                        <p>Hub Cap</p>
                    </div>
                </div>
            </section>

            <section class="reviews">
                <h2>DMC Delorean Reviews</h2>
                <ul class="review-list">
                    <li>"So fast it's almost like traveling in time." <span>(4/5)</span></li>
                    <li>"Coolest ride on the road." <span>(4/5)</span></li>
                    <li>"I'm feeling McFly!" <span>(5/5)</span></li>
                    <li>"The most futuristic ride of our day." <span>(4.5/5)</span></li>
                    <li>"80's livin' and I love it!" <span>(5/5)</span></li>
                </ul>
            </section>
        </main>

        <%- include("./partials/footer") %>
    </div>
</body>
</html>
